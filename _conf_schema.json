{
  "tshock_host": {
    "description": "REST API 地址",
    "type": "string",
    "default": "",
    "hint": "例如 http://1.2.3.4:7878"
  },
  "auth_mode": {
    "description": "认证模式",
    "type": "string",
    "default": "password",
    "options": [
      "password",
      "token"
    ],
    "hint": "password=账号密码自动申请 token；token=使用现成 token。"
  },
  "tshock_username": {
    "description": "TShock 用户名",
    "type": "string",
    "default": "",
    "hint": "auth_mode=password 时填写。"
  },
  "tshock_password": {
    "description": "TShock 密码",
    "type": "string",
    "default": "",
    "hint": "auth_mode=password 时填写。"
  },
  "tshock_token": {
    "description": "现成 token",
    "type": "string",
    "default": "",
    "hint": "auth_mode=token 时填写。"
  },
  "tshock_token_endpoint": {
    "description": "token 接口路径",
    "type": "string",
    "default": "/token/create",
    "hint": "通常保持默认；也可填 /v2/token/create。"
  },
  "session_ids": {
    "description": "通知 session",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "通过 /sid 获取，例如 default:GroupMessage:1021285757。"
  },
  "group_ids": {
    "description": "允许群 ID",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "只填写群号字符串。"
  },
  "admin_ids": {
    "description": "管理员 ID",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "允许使用 /tc 和 /tsdebug 的平台用户 ID。"
  },
  "notify_join_leave": {
    "description": "上下线通知",
    "type": "bool",
    "default": true
  },
  "poll_interval": {
    "description": "轮询间隔秒",
    "type": "int",
    "default": 30,
    "hint": "最低按 5 秒处理。"
  }
}
